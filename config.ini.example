# Generated with the AstraMeter config generator.
# Re-import this file there any time to keep editing.

[GENERAL]
DEVICE_TYPE = ct002
SKIP_POWERMETER_TEST = False

[HOMEASSISTANT]
CURRENT_POWER_ENTITY = sensor.angepasste_hausleistung
SMOOTH_TARGET_ALPHA = 0.3
MAX_SMOOTH_STEP = 300
DEADBand = 5
POWER_OFFSET = 1
POWER_MULTIPLIER = 1

# === SOC-basierte Lastverteilung (optional) ===
# Aktiviere SOC-basierte faire Batterie-Verteilung für Multi-Battery-Setups
# SOC_DISTRIBUTION_ENABLED = True

# MAC → Home Assistant SOC-Sensor Mapping
# Format: MAC_ADDRESS=sensor.entity_id
# Beispiel für 2 B2500 Batterien:
# SOC_SENSOR_MAP = 60323bd12622=sensor.a1_b2500_1_a1_battery_level,60323bd14c21=sensor.a2_b2500_2_a2_battery_level
# SOC_SENSOR_MAP =

# Fallback nach Timeout auf gleichmäßige Verteilung (Sekunden, 0=deaktiviert)
# Wenn Sensoren länger als diese Zeit nicht erreichbar sind, wird zu 50/50 Verteilung gewechselt
# SOC_FALLBACK_TIMEOUT_SECONDS = 300

[CT002]
MIN_DC_OUTPUT = 20
